{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:PLUGIN_ROOT\\scripts\\session-start.ps1\"",
            "timeout": 10,
            "statusMessage": "Detecting VibeBus project"
          }
        ]
      }
    ]
  }
}
